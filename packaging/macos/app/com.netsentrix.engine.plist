<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Embedded-daemon variant registered from the app via SMAppService
  (Settings → Engine process). Ships inside NetSentrix.app at
  Contents/Library/LaunchDaemons/ when built with `make bundle-full`.

  BundleProgram is resolved relative to the app bundle, so the engine binary
  travels with the app. Runs as root (LaunchDaemon) so :53 can bind.
  Same env layout as packaging/macos/launchd/com.netsentrix.engine.plist —
  keep the two in sync.
-->
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.netsentrix.engine</string>
	<key>BundleProgram</key>
	<string>Contents/Resources/bin/netsentrix-engine</string>
	<key>AssociatedBundleIdentifiers</key>
	<array>
		<string>com.netsentrix.app</string>
	</array>
	<key>EnvironmentVariables</key>
	<dict>
		<key>NETSENTRIX_CONFIG</key>
		<string>/usr/local/etc/NetSentrix/config.toml</string>
		<key>NETSENTRIX_DATA_DIR</key>
		<string>/usr/local/var/netsentrix</string>
		<key>NETSENTRIX_TOKEN_FILE</key>
		<string>/usr/local/var/netsentrix/NetSentrix/api.token</string>
	</dict>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>ThrottleInterval</key>
	<integer>10</integer>
	<key>StandardOutPath</key>
	<string>/var/log/netsentrix-engine.log</string>
	<key>StandardErrorPath</key>
	<string>/var/log/netsentrix-engine.err</string>
</dict>
</plist>
